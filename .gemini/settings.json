{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "$GITHUB_TOKEN"
      }
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["chrome-devtools-mcp@latest"]
    },
    "notion": {
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": {
        "NOTION_TOKEN": "$NOTION_TOKEN"
      }
    },
    "firebase": {
      "command": "npx",
      "args": ["-y", "firebase-tools@latest", "mcp"]
    },
    "vibe_kanban": {
      "command": "npx",
      "args": ["-y", "vibe-kanban@latest", "--mcp"]
    }
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "notify-permission",
            "type": "command",
            "command": "$GEMINI_PROJECT_DIR/.gemini/hooks/notify-permission.sh"
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "run_shell_command|run_command|bash|sh",
        "hooks": [
          {
            "name": "block-dangerous-commands",
            "type": "command",
            "command": "$GEMINI_PROJECT_DIR/.gemini/hooks/block-dangerous-commands.js"
          }
        ]
      }
    ]
  }
}
