rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function softDeleteFields() {
      return ['deletedAt', 'deletedByUid', 'deletedPurgeAt'];
    }

    function eventBodyFields() {
      return [
        'title',
        'time',
        'registrationDeadline',
        'city',
        'district',
        'meetPlace',
        'route',
        'distanceKm',
        'maxParticipants',
        'paceSec',
        'runType',
        'description'
      ];
    }

    function eventCounterFields() {
      return ['remainingSeats', 'participantsCount'];
    }

    function hostEventBodyUpdateFields() {
      return [
        'title',
        'time',
        'registrationDeadline',
        'city',
        'district',
        'meetPlace',
        'route',
        'distanceKm',
        'maxParticipants',
        'paceSec',
        'runType',
        'description',
        'remainingSeats'
      ];
    }

    function softDeleteRetentionWindow() {
      return duration.value(90, 'd');
    }

    function softDeleteRequestSkewWindow() {
      return duration.value(5, 'm');
    }

    function isSoftDeletedData(data) {
      return data.keys().hasAny(['deletedAt']);
    }

    function isActiveData(data) {
      return !isSoftDeletedData(data);
    }

    function postPath(postId) {
      return /databases/$(database)/documents/posts/$(postId);
    }

    function postHistoryPath(postId, historyId) {
      return /databases/$(database)/documents/posts/$(postId)/history/$(historyId);
    }

    function isActivePost(postId) {
      return exists(postPath(postId))
        && isActiveData(get(postPath(postId)).data);
    }

    function isPostAuthor(postId) {
      return isSignedIn()
        && exists(postPath(postId))
        && request.auth.uid == get(postPath(postId)).data.authorUid;
    }

    function postCommentPath(postId, commentId) {
      return /databases/$(database)/documents/posts/$(postId)/comments/$(commentId);
    }

    function postCommentHistoryPath(postId, commentId, historyId) {
      return /databases/$(database)/documents/posts/$(postId)/comments/$(commentId)/history/$(historyId);
    }

    function isActivePostComment(postId, commentId) {
      return isActivePost(postId)
        && exists(postCommentPath(postId, commentId))
        && isActiveData(get(postCommentPath(postId, commentId)).data);
    }

    function isPostCommentAuthor(postId, commentId) {
      return isSignedIn()
        && isActivePostComment(postId, commentId)
        && request.auth.uid == get(postCommentPath(postId, commentId)).data.authorUid;
    }

    function isValidPostCommentHistoryCreate() {
      return request.resource.data.keys().hasAll(['content', 'editedAt'])
        && request.resource.data.keys().hasOnly(['content', 'editedAt'])
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 500
        && request.resource.data.editedAt == request.time;
    }

    function postCommentEditFields() {
      return ['comment', 'updatedAt', 'isEdited', 'lastEditHistoryId'];
    }

    function isPostCommentTextEditUpdate(postId, commentId) {
      let historyPath = postCommentHistoryPath(
        postId,
        commentId,
        request.resource.data.lastEditHistoryId
      );
      return request.auth.uid == resource.data.authorUid
        && isActiveData(resource.data)
        && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(accountDeletionManagedFields())
        && !affectsSoftDeleteFields()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(postCommentEditFields())
        && request.resource.data.keys().hasAll(postCommentEditFields())
        && request.resource.data.comment is string
        && request.resource.data.comment.size() > 0
        && request.resource.data.comment.size() <= 500
        && request.resource.data.comment != resource.data.comment
        && request.resource.data.updatedAt == request.time
        && request.resource.data.isEdited == true
        && request.resource.data.lastEditHistoryId is string
        && request.resource.data.lastEditHistoryId.size() > 0
        && !exists(historyPath)
        && existsAfter(historyPath)
        && getAfter(historyPath).data.content == resource.data.comment
        && getAfter(historyPath).data.editedAt == request.time;
    }

    function isPostCommentNonTextAuthorUpdate() {
      return request.auth.uid == resource.data.authorUid
        && isActiveData(resource.data)
        && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(accountDeletionManagedFields())
        && !affectsSoftDeleteFields()
        && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(postCommentEditFields());
    }

    function isPostCommentHistoryCreate(postId, commentId, historyId) {
      let parentPath = postCommentPath(postId, commentId);
      return isPostCommentAuthor(postId, commentId)
        && isValidPostCommentHistoryCreate()
        && request.resource.data.content == get(parentPath).data.comment
        && existsAfter(parentPath)
        && isActiveData(getAfter(parentPath).data)
        && getAfter(parentPath).data.comment is string
        && getAfter(parentPath).data.comment.size() > 0
        && getAfter(parentPath).data.comment.size() <= 500
        && getAfter(parentPath).data.comment != get(parentPath).data.comment
        && getAfter(parentPath).data.updatedAt == request.time
        && getAfter(parentPath).data.isEdited == true
        && getAfter(parentPath).data.lastEditHistoryId == historyId;
    }

    function eventPath(eventId) {
      return /databases/$(database)/documents/events/$(eventId);
    }

    function isActiveEvent(eventId) {
      return exists(eventPath(eventId))
        && isActiveData(get(eventPath(eventId)).data);
    }

    function isEventHost(eventId) {
      return isSignedIn()
        && exists(eventPath(eventId))
        && request.auth.uid == get(eventPath(eventId)).data.hostUid;
    }

    function affectsSoftDeleteFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(softDeleteFields());
    }

    function isSoftDeleteUpdateBy(actorUid) {
      let deletedAt = request.resource.data.get('deletedAt', request.time);
      let deletedPurgeAt = request.resource.data.get('deletedPurgeAt', request.time);
      return !resource.data.keys().hasAny(softDeleteFields())
        && request.resource.data.keys().hasAll(softDeleteFields())
        && request.resource.data.diff(resource.data).addedKeys().hasAll(softDeleteFields())
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(softDeleteFields())
        && request.resource.data.get('deletedByUid', '') == actorUid
        && deletedAt is timestamp
        && deletedPurgeAt is timestamp
        && deletedPurgeAt == deletedAt + softDeleteRetentionWindow()
        && deletedAt >= request.time - softDeleteRequestSkewWindow()
        && deletedAt <= request.time + softDeleteRequestSkewWindow();
    }

    function isPostCounterUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['commentsCount', 'likesCount'])
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['commentsCount'])
          || (request.resource.data.commentsCount is number
              && request.resource.data.commentsCount >= 0)
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['likesCount'])
          || (request.resource.data.likesCount is number
              && request.resource.data.likesCount >= 0)
        );
    }

    function isEventCounterUpdate() {
      let remainingSeats = request.resource.data.get('remainingSeats', -1);
      let participantsCount = request.resource.data.get('participantsCount', -1);
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(eventCounterFields())
        && remainingSeats is number
        && participantsCount is number
        && remainingSeats >= 0
        && participantsCount >= 0
        && (remainingSeats + participantsCount) == resource.data.maxParticipants;
    }

    function isHostRemainingSeatsRecalculation() {
      return !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['remainingSeats'])
        || (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['maxParticipants'])
          && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['participantsCount'])
          && request.resource.data.maxParticipants is number
          && resource.data.participantsCount is number
          && request.resource.data.remainingSeats is number
          && request.resource.data.remainingSeats
            == request.resource.data.maxParticipants - resource.data.participantsCount
          && request.resource.data.remainingSeats >= 0
        );
    }

    function isHostEventBodyUpdateBeforeStart() {
      return resource.data.keys().hasAll(['hostUid', 'time'])
        && request.resource.data.keys().hasAll(['hostUid', 'time'])
        && isSignedIn()
        && request.auth.uid == resource.data.hostUid
        && isActiveData(resource.data)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(hostEventBodyUpdateFields())
        && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(accountDeletionManagedFields())
        && !affectsSoftDeleteFields()
        && resource.data.time is timestamp
        && request.resource.data.time is timestamp
        && request.time < resource.data.time
        && request.resource.data.time > request.time
        && isHostRemainingSeatsRecalculation()
        && (!request.resource.data.keys().hasAny(['maxParticipants'])
            || !('participantsCount' in resource.data)
            || request.resource.data.maxParticipants >= resource.data.participantsCount);
    }

    function isHostEventSoftDeleteBeforeStart() {
      return resource.data.keys().hasAll(['hostUid', 'time'])
        && request.resource.data.keys().hasAll(['hostUid', 'time'])
        && isSignedIn()
        && request.auth.uid == resource.data.hostUid
        && isActiveData(resource.data)
        && resource.data.time is timestamp
        && request.time < resource.data.time
        && isSoftDeleteUpdateBy(request.auth.uid);
    }

    function isValidPostHistoryCreate() {
      return request.resource.data.keys().hasAll(['title', 'content', 'editedAt'])
        && request.resource.data.keys().hasOnly(['title', 'content', 'editedAt'])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 120
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 10000
        && request.resource.data.editedAt == request.time;
    }

    function postEditFields() {
      return ['title', 'content', 'updatedAt', 'isEdited', 'lastEditHistoryId'];
    }

    function isPostTextEditUpdate(postId) {
      let historyPath = postHistoryPath(
        postId,
        request.resource.data.lastEditHistoryId
      );
      return request.auth.uid == resource.data.authorUid
        && isActiveData(resource.data)
        && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(accountDeletionManagedFields())
        && !affectsSoftDeleteFields()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(postEditFields())
        && request.resource.data.keys().hasAll(postEditFields())
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 120
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 10000
        && (
          request.resource.data.title != resource.data.title
          || request.resource.data.content != resource.data.content
        )
        && request.resource.data.updatedAt == request.time
        && request.resource.data.isEdited == true
        && request.resource.data.lastEditHistoryId is string
        && request.resource.data.lastEditHistoryId.size() > 0
        && !exists(historyPath)
        && existsAfter(historyPath)
        && getAfter(historyPath).data.title == resource.data.title
        && getAfter(historyPath).data.content == resource.data.content
        && getAfter(historyPath).data.editedAt == request.time;
    }

    function isPostNonTextAuthorUpdate() {
      return request.auth.uid == resource.data.authorUid
        && isActiveData(resource.data)
        && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(accountDeletionManagedFields())
        && !affectsSoftDeleteFields()
        && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(postEditFields());
    }

    function isPostHistoryCreate(postId, historyId) {
      let parentPath = postPath(postId);
      return isPostAuthor(postId)
        && isActivePost(postId)
        && isValidPostHistoryCreate()
        && request.resource.data.title == get(parentPath).data.title
        && request.resource.data.content == get(parentPath).data.content
        && existsAfter(parentPath)
        && isActiveData(getAfter(parentPath).data)
        && getAfter(parentPath).data.title is string
        && getAfter(parentPath).data.title.size() > 0
        && getAfter(parentPath).data.title.size() <= 120
        && getAfter(parentPath).data.content is string
        && getAfter(parentPath).data.content.size() > 0
        && getAfter(parentPath).data.content.size() <= 10000
        && (
          getAfter(parentPath).data.title != get(parentPath).data.title
          || getAfter(parentPath).data.content != get(parentPath).data.content
        )
        && getAfter(parentPath).data.updatedAt == request.time
        && getAfter(parentPath).data.isEdited == true
        && getAfter(parentPath).data.lastEditHistoryId == historyId;
    }

    function isValidFavoriteCreate(targetId) {
      return request.resource.data.keys().hasAll(['targetId', 'createdAt'])
        && request.resource.data.keys().hasOnly(['targetId', 'createdAt'])
        && request.resource.data.targetId == targetId
        && request.resource.data.targetId is string
        && request.resource.data.targetId.matches('^\\S(.*\\S)?$')
        && request.resource.data.createdAt == request.time;
    }

    function protectedUserProfileFields() {
      return [
        'followersCount',
        'followingCount',
        'privacy',
        'accountStatus',
        'deletionRequestedAt',
        'deletionScheduledFor'
      ];
    }

    function protectedUserProfileCreateFields() {
      return [
        'followersCount',
        'followingCount',
        'privacy',
        'deletionRequestedAt',
        'deletionScheduledFor'
      ];
    }

    function accountDeletionManagedFields() {
      return [
        'accountDeletionHidden',
        'accountDeletionHiddenAt',
        'accountDeletionHiddenBy',
        'accountDeletionRequestUid',
        'cancelledByAccountDeletion',
        'cancelledAt',
        'actorDeleted'
      ];
    }

    function accountDeletionNotificationFields() {
      return ['accountDeletionRequestUid', 'accountDeletionReason', 'actorDeleted'];
    }

    match /users/{userId} {
      // 公開檔案頁面可被未登入訪客瀏覽（FR-007）
      allow read: if true;

      allow create: if isSignedIn()
        && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(protectedUserProfileCreateFields())
        && (
          !request.resource.data.keys().hasAny(['accountStatus'])
          || request.resource.data.accountStatus == 'active'
        );

      // 限制本人寫入；只有當「這次更新實際動到 bio 欄位」才驗證 bio
      // 的型別與長度。這避免既有 over-length bio 在 rules 上線後被鎖死，
      // 讓使用者仍能正常更新 name / photoURL 等欄位。
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(protectedUserProfileFields())
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['bio'])
          || (request.resource.data.bio is string && request.resource.data.bio.size() <= 150)
        );

      allow delete: if false;

      match /weatherFavorites/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      match /favoritePosts/{postId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidFavoriteCreate(postId);
        allow delete: if isOwner(userId);
        allow update: if false;
      }

      match /favoriteEvents/{eventId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidFavoriteCreate(eventId);
        allow delete: if isOwner(userId);
        allow update: if false;
      }

      match /following/{targetUid} {
        allow read: if true;
        allow write: if false;
      }

      match /followers/{followerUid} {
        allow read: if true;
        allow write: if false;
      }
    }

    match /posts/{postId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.authorUid == request.auth.uid
        && !request.resource.data.keys().hasAny(accountDeletionManagedFields())
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 120
        && request.resource.data.content is string
        && request.resource.data.content.size() <= 5000;

      // 作者可更新非文字欄位；title/content 編輯必須與 history 建立同批送出。
      // 軟刪除只能新增 retention 欄位；非作者只能更新 commentsCount / likesCount（transaction 用）。
      allow update: if isSignedIn() && (
        isPostNonTextAuthorUpdate()
        || isPostTextEditUpdate(postId)
        || (
          request.auth.uid == resource.data.authorUid
          && isSoftDeleteUpdateBy(request.auth.uid)
        )
        || (isActiveData(resource.data) && isPostCounterUpdate())
      );

      allow delete: if isSignedIn()
        && request.auth.uid == resource.data.authorUid;

      match /likes/{uid} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.auth.uid == uid;
        // 本人可刪自己的 like，或文章作者 deletePost cascade
        allow delete: if isSignedIn() && (
          request.auth.uid == uid
          || request.auth.uid == get(/databases/$(database)/documents/posts/$(postId)).data.authorUid
        );
      }

      match /history/{historyId} {
        allow read: if isActivePost(postId);

        allow create: if isPostHistoryCreate(postId, historyId);

        allow update, delete: if false;
      }
    }

    // collectionGroup('comments') is intentionally server-only for member dashboard comments.
    match /{path=**}/comments/{commentId} {
      allow read: if false;
    }

    // collectionGroup('likes') 需要的規則
    match /{path=**}/likes/{uid} {
      allow read: if isSignedIn();
      allow create, delete: if false;
    }

    match /posts/{postId}/comments/{commentId} {
      allow read: if isActivePost(postId);

      allow create: if isSignedIn()
        && isActivePost(postId)
        && request.resource.data.authorUid == request.auth.uid
        && !request.resource.data.keys().hasAny(accountDeletionManagedFields())
        && request.resource.data.comment is string
        && request.resource.data.comment.size() <= 500;

      allow update: if isSignedIn()
        && isActivePost(postId)
        && (
          isPostCommentNonTextAuthorUpdate()
          || isPostCommentTextEditUpdate(postId, commentId)
          || (
            (request.auth.uid == resource.data.authorUid || isPostAuthor(postId))
            && isSoftDeleteUpdateBy(request.auth.uid)
          )
        );

      // 留言作者刪自己留言，或文章作者 deletePost cascade
      allow delete: if isSignedIn() && isActivePost(postId) && (
        request.auth.uid == resource.data.authorUid
        || isPostAuthor(postId)
      );

      match /history/{historyId} {
        allow read: if isActivePostComment(postId, commentId);

        allow create: if isPostCommentHistoryCreate(postId, commentId, historyId);

        allow update, delete: if false;
      }
    }

    // -------------------------
    // ✅ Strava collections
    // -------------------------

    // stravaTokens: server-only（Admin SDK 存取）
    match /stravaTokens/{uid} {
      allow read, write: if false;
    }

    // stravaConnections: 本人可讀，僅 server 可寫
    match /stravaConnections/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    // stravaActivities: 本人可讀，僅 server 可寫
    match /stravaActivities/{id} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.uid;
      allow write: if false;
    }

    // -------------------------
    // ✅ events + participants
    // -------------------------

    // collectionGroup('participants') 需要的全域規則
    match /{path=**}/participants/{uid} {
      allow read: if true;
    }

    match /events/{eventId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.hostUid == request.auth.uid
        && !request.resource.data.keys().hasAny(accountDeletionManagedFields())
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 120
        && request.resource.data.time is timestamp
        && request.resource.data.registrationDeadline is timestamp
        && request.resource.data.distanceKm is number
        && request.resource.data.maxParticipants is number;

      allow delete: if false;

      // 主揪：開始前可更新活動本體；非本體 counter 更新維持獨立分支。
      allow update: if (
        isHostEventBodyUpdateBeforeStart()
      ) || (
        isHostEventSoftDeleteBeforeStart()
      ) || (
        isSignedIn()
        && isActiveData(resource.data)
        && isEventCounterUpdate()
      );

      // participants 子集合
      match /participants/{uid} {
        allow read: if true;

        allow create: if isSignedIn()
          && isActiveEvent(eventId)
          && request.auth.uid == uid
          && request.resource.data.uid == uid
          && request.resource.data.eventId == eventId
          && !request.resource.data.keys().hasAny(accountDeletionManagedFields())
          && request.resource.data.name is string
          && request.resource.data.photoURL is string;

        // ✅ 本人可退出（刪自己的紀錄），或主揪刪除整個活動時可刪所有 participants
        allow delete: if isSignedIn() && isActiveEvent(eventId) && (
          request.auth.uid == uid
          || isEventHost(eventId)
        );

        allow update: if false;
      }

      // -------------------------
      // ✅ comments + history
      // -------------------------

      match /comments/{commentId} {
        allow read: if true;

        allow create: if isSignedIn()
          && isActiveEvent(eventId)
          && request.resource.data.authorUid == request.auth.uid
          && !request.resource.data.keys().hasAny(accountDeletionManagedFields())
          && request.resource.data.content is string
          && request.resource.data.content.size() <= 500;

        allow update: if isSignedIn()
          && isActiveEvent(eventId)
          && (
            (
              request.auth.uid == resource.data.authorUid
              && isActiveData(resource.data)
              && !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(accountDeletionManagedFields())
              && !affectsSoftDeleteFields()
            )
            || (
              (request.auth.uid == resource.data.authorUid || isEventHost(eventId))
              && isSoftDeleteUpdateBy(request.auth.uid)
            )
          );

        allow delete: if false;

        // history 子集合（編輯記錄）
        match /history/{historyId} {
          allow read: if true;

          // 編輯留言時 transaction 內建立（僅留言作者可寫入）
          allow create: if isSignedIn()
            && isActiveEvent(eventId)
            && request.auth.uid == get(/databases/$(database)/documents/events/$(eventId)/comments/$(commentId)).data.authorUid;

          allow delete: if false;

          allow update: if false;
        }
      }
    }

    // -------------------------
    // ✅ notifications
    // -------------------------

    match /notifications/{notificationId} {
      // 任何登入者可建立通知（recipientUid 不能是自己）
      allow create: if isSignedIn()
        && request.resource.data.recipientUid is string
        && !request.resource.data.keys().hasAny(accountDeletionNotificationFields())
        && request.resource.data.recipientUid != request.auth.uid
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.type in [
          'event_modified', 'event_cancelled', 'post_new_comment',
          'post_comment_reply', 'event_host_comment',
          'event_participant_comment', 'event_comment_reply',
          'event_host_joined',
        ]
        && request.resource.data.read == false
        && request.resource.data.createdAt == request.time;

      // 只有接收者可讀取自己的通知
      allow read: if isSignedIn()
        && resource.data.recipientUid == request.auth.uid;

      // 只有接收者可更新（僅 read 欄位）
      allow update: if isSignedIn()
        && resource.data.recipientUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);

      // 不允許刪除
      allow delete: if false;
    }

    match /accountDeletionRequests/{uid} {
      allow read, write: if false;
    }
  }
}
