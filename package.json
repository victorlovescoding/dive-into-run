{
  "name": "dive-into-run",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src specs",
    "lint:changed": "bash scripts/lint-changed.sh",
    "test": "vitest",
    "type-check": "tsc --noEmit",
    "spellcheck": "cspell lint \"src/**/*.{js,jsx}\" \"specs/**/*.{js,jsx}\"",
    "type-check:changed": "bash scripts/type-check-changed.sh",
    "type-check:branch": "bash scripts/type-check-branch.sh",
    "lint:branch": "bash scripts/lint-branch.sh",
    "test:branch": "bash scripts/test-branch.sh",
    "test:e2e:branch": "bash scripts/test-e2e-branch.sh",
    "test:e2e:emulator": "npx playwright test --config playwright.emulator.config.mjs",
    "webhook:create": "node scripts/strava-webhook.js create",
    "webhook:view": "node scripts/strava-webhook.js view",
    "webhook:delete": "node scripts/strava-webhook.js delete",
    "prepare": "husky"
  },
  "dependencies": {
    "@mapbox/polyline": "^1.2.1",
    "firebase": "^12.1.0",
    "firebase-admin": "^13.7.0",
    "leaflet": "^1.9.4",
    "leaflet-draw": "^1.0.4",
    "leaflet-geosearch": "^4.2.2",
    "next": "15.4.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-leaflet": "^5.0.0",
    "topojson-client": "^3.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet-draw": "^1.0.13",
    "@types/node": "^25.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "confusing-browser-globals": "^1.0.11",
    "cspell": "^10.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "15.4.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^27.4.0",
    "tailwindcss": "^4",
    "taiwan-atlas": "^2021.9.20",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
