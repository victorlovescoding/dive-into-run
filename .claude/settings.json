{
  "permissions": {
    "allow": [
      "Bash(npx playwright:*)",
      "Bash(npx cspell:*)",
      "Bash(npx husky:*)",
      "Bash(npx next:*)",
      "Bash(bash .specify/scripts/bash/*)",
      "Bash(.specify/scripts/bash/*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)",
      "Bash(gh api repos/*/pulls/*)",
      "mcp__firebase__firebase_get_project",
      "mcp__firebase__firebase_get_sdk_config",
      "mcp__firebase__firebase_get_security_rules",
      "mcp__firebase__firebase_get_environment",
      "mcp__firebase__firebase_validate_security_rules",
      "mcp__firebase__firebase_list_projects",
      "mcp__firebase__firebase_list_apps",
      "mcp__firebase__firestore_get_document",
      "mcp__firebase__firestore_get_database",
      "mcp__firebase__firestore_get_index",
      "mcp__firebase__firestore_list_databases",
      "mcp__firebase__firestore_list_collections",
      "mcp__firebase__firestore_list_documents",
      "mcp__firebase__firestore_list_indexes",
      "mcp__firebase__firestore_query_collection",
      "mcp__chrome-devtools__navigate_page",
      "mcp__chrome-devtools__take_snapshot",
      "mcp__chrome-devtools__take_screenshot",
      "mcp__chrome-devtools__evaluate_script",
      "mcp__chrome-devtools__list_pages",
      "mcp__chrome-devtools__list_console_messages",
      "mcp__chrome-devtools__list_network_requests",
      "mcp__chrome-devtools__wait_for",
      "WebFetch(domain:firebase.google.com)",
      "WebFetch(domain:typescript-eslint.io)",
      "WebFetch(domain:martinfowler.com)",
      "WebFetch(domain:blog.ray-realms.com)",
      "WebFetch(domain:alexop.dev)",
      "WebFetch(domain:stripe.dev)",
      "WebFetch(domain:www.datadoghq.com)",
      "WebFetch(domain:openai.com)",
      "WebFetch(domain:www.infoq.com)",
      "WebFetch(domain:medium.com)",
      "WebFetch(domain:milvus.io)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./firebase-adminsdk*.json)",
      "Read(./secrets/**)",
      "Bash(firebase delete:*)",
      "Bash(firebase firestore:delete:*)",
      "mcp__firebase__firestore_delete_document",
      "mcp__firebase__firestore_delete_database",
      "mcp__firebase__firestore_delete_index"
    ]
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/notify-permission.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-dangerous-commands.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_FILE_PATH\""
          },
          {
            "type": "command",
            "command": "npx eslint \"$CLAUDE_FILE_PATH\" --max-warnings 0 2>&1; exit 0"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "chrome-devtools-mcp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  }
}
