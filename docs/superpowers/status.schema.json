{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/victorlovescoding/dive-into-run/docs/superpowers/status.schema.json",
  "title": "Superpowers Workflow Status",
  "oneOf": [
    {
      "$ref": "#/$defs/statusV1"
    },
    {
      "$ref": "#/$defs/statusV2"
    },
    {
      "$ref": "#/$defs/statusV3"
    }
  ],
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "nullableString": {
      "type": [
        "string",
        "null"
      ]
    },
    "stringList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "verificationResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "exitCode",
        "summary",
        "verifiedAt"
      ],
      "properties": {
        "command": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "exitCode": {
          "type": "integer",
          "minimum": 0
        },
        "summary": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "verifiedAt": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "activeTaskV1": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "state",
            "engineer",
            "reviewer",
            "attempt",
            "ownedFiles",
            "startedAt"
          ],
          "properties": {
            "id": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "state": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "engineer": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "reviewer": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "attempt": {
              "type": "integer",
              "minimum": 1
            },
            "ownedFiles": {
              "$ref": "#/$defs/stringList"
            },
            "startedAt": {
              "$ref": "#/$defs/nonEmptyString"
            }
          }
        }
      ]
    },
    "activeTaskV2": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/nonEmptyString"
        }
      ]
    },
    "taskState": {
      "enum": [
        "todo",
        "ready",
        "in_progress",
        "engineer_done",
        "review_passed",
        "review_rejected",
        "completed",
        "blocked"
      ]
    },
    "reviewerDecision": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "decision",
            "reviewer",
            "summary",
            "decidedAt"
          ],
          "properties": {
            "decision": {
              "enum": [
                "review_passed",
                "review_rejected",
                "blocked"
              ]
            },
            "reviewer": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "summary": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "decidedAt": {
              "$ref": "#/$defs/nonEmptyString"
            }
          }
        }
      ]
    },
    "verificationPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "expectedSignal",
        "lastRun"
      ],
      "properties": {
        "command": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "expectedSignal": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "lastRun": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/verificationResult"
            }
          ]
        }
      }
    },
    "taskEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engineerReport",
        "reviewerReport",
        "commandOutputSummary",
        "changedFilesSummary"
      ],
      "properties": {
        "engineerReport": {
          "$ref": "#/$defs/nullableString"
        },
        "reviewerReport": {
          "$ref": "#/$defs/nullableString"
        },
        "commandOutputSummary": {
          "$ref": "#/$defs/stringList"
        },
        "changedFilesSummary": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "taskV2": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "state",
        "attempt",
        "wave",
        "engineer",
        "reviewer",
        "scope",
        "nonScope",
        "ownedFiles",
        "readOnlyContext",
        "dependencies",
        "engineerInstructions",
        "acceptanceCriteria",
        "verification",
        "reviewerPassCriteria",
        "reviewerRejectCriteria",
        "reviewerDecision",
        "evidence"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "state": {
          "$ref": "#/$defs/taskState"
        },
        "attempt": {
          "type": "integer",
          "minimum": 1
        },
        "wave": {
          "oneOf": [
            {
              "$ref": "#/$defs/nonEmptyString"
            },
            {
              "type": "integer",
              "minimum": 1
            }
          ]
        },
        "engineer": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "reviewer": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "scope": {
          "$ref": "#/$defs/stringList"
        },
        "nonScope": {
          "$ref": "#/$defs/stringList"
        },
        "ownedFiles": {
          "$ref": "#/$defs/stringList"
        },
        "readOnlyContext": {
          "$ref": "#/$defs/stringList"
        },
        "dependencies": {
          "$ref": "#/$defs/stringList"
        },
        "engineerInstructions": {
          "$ref": "#/$defs/stringList"
        },
        "acceptanceCriteria": {
          "$ref": "#/$defs/stringList"
        },
        "verification": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verificationPlan"
          }
        },
        "reviewerPassCriteria": {
          "$ref": "#/$defs/stringList"
        },
        "reviewerRejectCriteria": {
          "$ref": "#/$defs/stringList"
        },
        "reviewerDecision": {
          "$ref": "#/$defs/reviewerDecision"
        },
        "evidence": {
          "$ref": "#/$defs/taskEvidence"
        }
      }
    },
    "authorizationBoundaryV3": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "edit",
        "commit",
        "push",
        "pullRequest",
        "ciWatch",
        "merge",
        "localMainSync",
        "deployFirestoreRules"
      ],
      "properties": {
        "edit": {
          "type": "boolean"
        },
        "commit": {
          "type": "boolean"
        },
        "push": {
          "type": "boolean"
        },
        "pullRequest": {
          "type": "boolean"
        },
        "ciWatch": {
          "type": "boolean"
        },
        "merge": {
          "type": "boolean"
        },
        "localMainSync": {
          "type": "boolean"
        },
        "deployFirestoreRules": {
          "type": "boolean"
        }
      }
    },
    "headSnapshotV3": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/nonEmptyString"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "ref": {
              "$ref": "#/$defs/nullableString"
            },
            "commit": {
              "$ref": "#/$defs/nullableString"
            },
            "sha": {
              "$ref": "#/$defs/nullableString"
            },
            "branch": {
              "$ref": "#/$defs/nullableString"
            },
            "remote": {
              "$ref": "#/$defs/nullableString"
            },
            "source": {
              "$ref": "#/$defs/nullableString"
            },
            "checkedAt": {
              "$ref": "#/$defs/nullableString"
            },
            "capturedAt": {
              "$ref": "#/$defs/nullableString"
            },
            "summary": {
              "$ref": "#/$defs/nullableString"
            }
          }
        }
      ]
    },
    "phaseCommitV3": {
      "oneOf": [
        {
          "$ref": "#/$defs/nonEmptyString"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "anyOf": [
            {
              "required": [
                "ref"
              ]
            },
            {
              "required": [
                "commit"
              ]
            },
            {
              "required": [
                "commitRef"
              ]
            },
            {
              "required": [
                "sha"
              ]
            }
          ],
          "properties": {
            "phase": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "ref": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "commit": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "commitRef": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "sha": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "summary": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "committedAt": {
              "$ref": "#/$defs/nonEmptyString"
            }
          }
        }
      ]
    },
    "deployEvidenceV3": {
      "oneOf": [
        {
          "$ref": "#/$defs/nonEmptyString"
        },
        {
          "$ref": "#/$defs/verificationResult"
        }
      ]
    },
    "rulesDeployStatusV3": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "required",
        "changed",
        "evidence",
        "deployedCommit"
      ],
      "properties": {
        "state": {
          "enum": [
            "not_applicable",
            "not_required",
            "required",
            "pending",
            "blocked",
            "deployed"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "changed": {
          "type": "boolean"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/deployEvidenceV3"
          }
        },
        "deployedCommit": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "incidentV3": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "state",
        "summary"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "state": {
          "enum": [
            "open",
            "mitigated",
            "resolved",
            "closed"
          ]
        },
        "summary": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "openedAt": {
          "$ref": "#/$defs/nullableString"
        },
        "closedAt": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "statusV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "feature",
        "branch",
        "worktree",
        "phase",
        "activeTask",
        "completedTasks",
        "blocked",
        "blockedReason",
        "lastVerification",
        "lastVerifiedCommit",
        "updatedAt"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "feature": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "branch": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "worktree": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "phase": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "activeTask": {
          "$ref": "#/$defs/activeTaskV1"
        },
        "completedTasks": {
          "$ref": "#/$defs/stringList"
        },
        "blocked": {
          "type": "boolean"
        },
        "blockedReason": {
          "$ref": "#/$defs/nullableString"
        },
        "lastVerification": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verificationResult"
          }
        },
        "lastVerifiedCommit": {
          "$ref": "#/$defs/nullableString"
        },
        "updatedAt": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "statusV2": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "feature",
        "branch",
        "worktree",
        "phase",
        "activeTask",
        "activeWave",
        "completedTasks",
        "tasks",
        "blocked",
        "blockedReason",
        "lastVerification",
        "lastVerifiedCommit",
        "updatedAt"
      ],
      "properties": {
        "schemaVersion": {
          "const": 2
        },
        "feature": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "branch": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "worktree": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "phase": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "activeTask": {
          "$ref": "#/$defs/activeTaskV2"
        },
        "activeWave": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/nonEmptyString"
            },
            {
              "type": "integer",
              "minimum": 1
            }
          ]
        },
        "completedTasks": {
          "$ref": "#/$defs/stringList"
        },
        "tasks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/taskV2"
          }
        },
        "blocked": {
          "type": "boolean"
        },
        "blockedReason": {
          "$ref": "#/$defs/nullableString"
        },
        "lastVerification": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verificationResult"
          }
        },
        "lastVerifiedCommit": {
          "$ref": "#/$defs/nullableString"
        },
        "updatedAt": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "statusV3": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "feature",
        "branch",
        "worktree",
        "phase",
        "activeTask",
        "activeWave",
        "authorizationBoundary",
        "currentHead",
        "remoteHead",
        "completedTasks",
        "tasks",
        "blocked",
        "blockedReason",
        "lastVerification",
        "lastVerifiedCommit",
        "phaseCommits",
        "rulesDeployStatus",
        "incidents",
        "updatedAt"
      ],
      "properties": {
        "schemaVersion": {
          "const": 3
        },
        "feature": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "branch": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "worktree": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "phase": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "activeTask": {
          "$ref": "#/$defs/activeTaskV2"
        },
        "activeWave": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/nonEmptyString"
            },
            {
              "type": "integer",
              "minimum": 1
            }
          ]
        },
        "authorizationBoundary": {
          "$ref": "#/$defs/authorizationBoundaryV3"
        },
        "currentHead": {
          "$ref": "#/$defs/headSnapshotV3"
        },
        "remoteHead": {
          "$ref": "#/$defs/headSnapshotV3"
        },
        "completedTasks": {
          "$ref": "#/$defs/stringList"
        },
        "tasks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/taskV2"
          }
        },
        "blocked": {
          "type": "boolean"
        },
        "blockedReason": {
          "$ref": "#/$defs/nullableString"
        },
        "lastVerification": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verificationResult"
          }
        },
        "lastVerifiedCommit": {
          "$ref": "#/$defs/nullableString"
        },
        "phaseCommits": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/phaseCommitV3"
          }
        },
        "rulesDeployStatus": {
          "$ref": "#/$defs/rulesDeployStatusV3"
        },
        "incidents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/incidentV3"
          }
        },
        "updatedAt": {
          "$ref": "#/$defs/nullableString"
        }
      }
    }
  }
}
