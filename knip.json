{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "next.config.mjs",
    "eslint.config.mjs",
    "postcss.config.mjs",
    "playwright*.config.mjs",
    "vitest.config.mjs",
    ".lighthouserc.cjs",
    "src/app/**/{page,layout,loading,error,not-found,route}.js",
    "src/app/**/{page,layout,loading,error,not-found,route}.jsx",
    "src/middleware.{js,mjs}",
    "scripts/**/*.{js,mjs}"
  ],
  "project": [
    "src/**/*.{js,jsx,mjs}",
    "scripts/**/*.{js,mjs}",
    "specs/**/*.{js,jsx,mjs}",
    "*.config.mjs",
    ".lighthouserc.cjs"
  ],
  "ignore": [
    ".next/**",
    "coverage/**",
    "lhci-report/**",
    "node_modules/**",
    "playwright-report/**",
    "reports/**",
    "test-results/**"
  ],
  "ignoreDependencies": [
    "@types/*",
    "firebase-functions-test"
  ],
  "workspaces": {
    ".": {
      "entry": [
        "next.config.mjs",
        "eslint.config.mjs",
        "postcss.config.mjs",
        "playwright*.config.mjs",
        "vitest.config.mjs",
        ".lighthouserc.cjs",
        "src/app/**/{page,layout,loading,error,not-found,route}.js",
        "src/app/**/{page,layout,loading,error,not-found,route}.jsx",
        "src/middleware.{js,mjs}",
        "scripts/**/*.{js,mjs}"
      ],
      "project": [
        "src/**/*.{js,jsx,mjs}",
        "scripts/**/*.{js,mjs}",
        "specs/**/*.{js,jsx,mjs}",
        "*.config.mjs",
        ".lighthouserc.cjs"
      ],
      "ignore": [
        ".next/**",
        "coverage/**",
        "lhci-report/**",
        "node_modules/**",
        "playwright-report/**",
        "reports/**",
        "test-results/**"
      ],
      "ignoreDependencies": [
        "@types/*",
        "tailwindcss"
      ]
    },
    "functions": {
      "entry": ["index.js"],
      "project": ["*.js"],
      "ignoreDependencies": ["firebase-functions-test"]
    }
  }
}
